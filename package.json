{
  "name": "winnow",
  "version": "1.0.0",
  "description": "Cursor CLI wrapper with Chinese translation middleware",
  "main": "dist/cli/index.js",
  "scripts": {
    "setup": "node scripts/run-setup.js",
    "preinstall": "node scripts/check-node-version.js",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run tests",
    "test:watch": "vitest tests",
    "doctor": "tsx src/cli/index.ts doctor",
    "status": "tsx src/cli/index.ts status",
    "ui": "node scripts/run-ui.js",
    "release:check": "npm run build && npm test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "bin": {
    "winnow": "dist/cli/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "commander": "^14.0.3",
    "node-pty": "^1.1.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
