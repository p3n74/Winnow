# Winnow — copy to .env and adjust (same keys as Console → Settings)
# Shell exports override .env when both are set.

WINNOW_TRANSLATOR_BACKEND=ollama
WINNOW_TRANSLATOR_TIMEOUT_MS=20000
WINNOW_TRANSLATOR_RETRIES=2
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TRANSLATION_MODEL=deepseek-v3
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Correct name is DEEPSEEK_API_KEY (no underscore between DEEP and SEEK). DEEP_SEEK_API_KEY is accepted as a legacy alias only.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
WINNOW_TRANSLATION_GLOSSARY=PR:拉取请求,branch:分支,commit:提交
WINNOW_INPUT_MODE=off
WINNOW_OUTPUT_MODE=off
WINNOW_PROFILE=engineering_exact
WINNOW_SHOW_ORIGINAL=false
WINNOW_DUAL_OUTPUT=false
WINNOW_CURSOR_COMMAND=cursor-agent
WINNOW_SESSION_ID=
WINNOW_UI_WORKSPACE_DIR=
WINNOW_LOGS_ENABLED=true
WINNOW_LOGS_DIR=.winnow/logs
WINNOW_AGENT_TRANSCRIPTS_DIR=
