WINNOW_TRANSLATOR_BACKEND=ollama
WINNOW_TRANSLATOR_TIMEOUT_MS=20000
WINNOW_TRANSLATOR_RETRIES=2
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TRANSLATION_MODEL=deepseek-v3
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
WINNOW_TRANSLATION_GLOSSARY=PR:拉取请求,branch:分支,commit:提交
WINNOW_INPUT_MODE=off
WINNOW_OUTPUT_MODE=off
WINNOW_PROFILE=engineering_exact
WINNOW_LOGS_ENABLED=true
WINNOW_LOGS_DIR=.winnow/logs
